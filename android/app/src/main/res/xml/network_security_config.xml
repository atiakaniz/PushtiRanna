<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- PushtiRanna talks to the bdapps backend at pushtiranna.nestorabyatia.xyz.
         That endpoint uses HTTPS, so cleartext is restricted to local-dev hosts only. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>   <!-- Android emulator -> host -->
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
